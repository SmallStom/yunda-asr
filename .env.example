# LLM 配置（Layer 4语义精修使用）
LLM_BASE_URL=http://192.168.1.119:8012/v1
LLM_MODEL=Qwen3.6-27B
LLM_API_KEY=dummy-key-for-local

# 本地ASR服务配置（VibeVoice格式，base_url不要带/v1后缀）
LOCAL_ASR_BASE_URL=http://192.168.1.119:8015
LOCAL_ASR_MODEL=vibevoice
LOCAL_ASR_API_KEY=dummy-key-for-local

# ASR 服务配置（Qwen3-ASR，OpenAI 兼容 /v1/audio/transcriptions 接口）
QWEN3_ASR_BASE_URL=http://192.168.1.119:8014
QWEN3_ASR_MODEL=/models/Qwen3-ASR-1.7B
QWEN3_ASR_API_KEY=dummy-key-for-local

# ElevenLabs ASR服务配置（https://elevenlabs.io/app/api/api-keys）
ELEVENLABS_ASR_MODEL=scribe_v1
ELEVENLABS_ASR_API_KEY=sk_your_elevenlabs_api_key_here

# API 服务配置
API_HOST=0.0.0.0
# Docker 宿主机映射端口（仅 docker-compose 使用，不传入容器）
HOST_PORT=8000
# 容器内监听端口（固定 8000，无需修改）
# API_PORT=8000
API_WORKERS=1
# API_KEY=your-internal-api-key
LOG_LEVEL=INFO
REQUEST_TIMEOUT=30.0

# LLM 并发与超时
LLM_MAX_CONCURRENCY=10
LLM_TIMEOUT=30.0

# 数据路径（默认使用项目内相对路径，Docker 部署时可保持默认）
# DATA_DIR=./data
# PROMPTS_DIR=./src/prompts
# HOTWORDS_PATH=./data/lexicon/hotwords.json

# 版本管理（可选，启动时自动激活指定版本）
# HOTWORDS_VERSION=v2
# ALIASES_VERSION=v2

# Dify 桥接配置（可选，dataset_id 通过请求体传入）
DIFY_ENABLED=false
DIFY_BASE_URL=http://localhost:5001
# DIFY_API_KEY=dataset-xxxxxxxx
